# Variables d'environnement Netlify pour l'envoi d'emails via SendGrid

# Cle API SendGrid (remplacer par votre vraie clé)
SENDGRID_API_KEY=SG.your_api_key_here

# Adresse expediteur verifiee dans SendGrid (Sender Identity)
SENDGRID_FROM_EMAIL=your-email@example.com

# Adresse de reception (facultatif, fallback: your-email@example.com)
SENDGRID_TO_EMAIL=your-email@example.com
